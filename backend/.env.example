# ============================================================
# Gideon backend environment — template (fill in real values)
# ============================================================

# ── Firebase (Admin SDK) ──────────────────────────────────
GIDEON_FIREBASE_PROJECT_ID=
GIDEON_FIREBASE_CLIENT_EMAIL=
GIDEON_FIREBASE_PRIVATE_KEY=

# ── Model routing (Vercel AI Gateway) ─────────────────────
# LLM_PROVIDER: auto = Gateway iff AI_GATEWAY_API_KEY set, else OpenAI fallback.
LLM_PROVIDER=auto
AI_GATEWAY_API_KEY=
# Optional model overrides (defaults: Claude Sonnet 4.5 + gpt-5.4-mini fast)
GATEWAY_FAST_MODEL=openai/gpt-5.4-mini
GATEWAY_DEFAULT_MODEL=anthropic/claude-sonnet-4.5
GATEWAY_REASONING_MODEL=anthropic/claude-sonnet-4.5
GATEWAY_RESEARCH_MODEL=anthropic/claude-sonnet-4.5
# EMBEDDING_PROVIDER: auto = Gateway iff key set, else OpenAI direct (1536 dims).
EMBEDDING_PROVIDER=auto
GATEWAY_EMBEDDING_MODEL=openai/text-embedding-3-small

# ── OpenAI (embeddings + LLM fallback) ────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_FAST_MODEL=gpt-5.4-mini
OPENAI_DEFAULT_MODEL=gpt-5.5
OPENAI_REASONING_MODEL=gpt-5.5
OPENAI_RESEARCH_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Exa AI (web intelligence) ─────────────────────────────
EXA_API_KEY=
WEB_SEARCH_PROVIDER=exa
WEB_EXTRACT_PROVIDER=exa
WEB_RESEARCH_PROVIDER=openai_graph
WEB_EXTRACT_FALLBACK=none

# ── Google Workspace integration ──────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_POST_AUTH_REDIRECT=

# ── HubSpot CRM integration ───────────────────────────────
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_REDIRECT_URI=
HUBSPOT_POST_AUTH_REDIRECT=

# ── Integration security ──────────────────────────────────
INTEGRATION_STATE_SECRET=
INTEGRATION_ENCRYPTION_KEY=

# ── App ───────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_BASE_URL=http://localhost:3001
FRONTEND_ORIGIN=http://localhost:3000
LOG_LEVEL=info

# ── AI execution feature flags ────────────────────────────
AI_V2_KILL_SWITCH=false
AI_TRACE_V2=true
SESSION_STATE_V2=true
ROUTE_V2_SHADOW=true
ROUTE_V2_ACTIVE=true
CONTEXT_V2=false
EXECUTION_V2=false
# Phase 3 — agentic ToolLoopAgent path (Vercel AI SDK multi-step). Default off.
AGENTIC_TOOLLOOP_V1=false

# ── Background worker (Google Cloud Tasks) ────────────────
LOCAL_WORKER_POLLING=false
GOOGLE_CLOUD_TASKS_QUEUE_PATH=
WORKER_TRIGGER_SECRET=
WORKER_WEBHOOK_URL=

# ── Email (SendGrid SMTP) ─────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=465
SMTP_USER=apikey
SMTP_PASS=
GIDEON_EMAIL=
GIDEON_NOREPLY_EMAIL=
